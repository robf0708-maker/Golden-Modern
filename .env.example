# Copie para .env e preencha. No Railway/VPS replique estes nomes nas variáveis de ambiente.
# Se o .env já foi commitado no Git no passado, rotacione todas as chaves (DB, Stripe, sessão, APIs).
DATABASE_URL=postgresql://postgres:SENHA@db.SEU_REF.supabase.co:5432/postgres
SESSION_SECRET=gere-uma-string-longa-aleatoria
NODE_ENV=production
PORT=5000

# Stripe (obrigatório fora do Replit)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# WhatsApp (opcional)
UAZAPI_URL=
UAZAPI_MASTER_TOKEN=
UAZAPI_INSTANCE_TOKEN=

# Email (opcional)
RESEND_API_KEY=

# --- Railway (painel) ---
# Build: npm run build | Start: npm start | Root Directory: pasta onde está este package.json
# Variáveis: copie as chaves acima (DATABASE_URL, SESSION_SECRET, STRIPE_*, etc.)
